for langName, _ in pairs(Languages) do
    local b = Instance.new("TextButton", LangScroll)
    b.Size = UDim2.new(1, 0, 0, 30)
    b.Text = langName
    b.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    b.TextColor3 = Color3.new(1, 1, 1)
    b.Font = Enum.Font.Gotham
    Instance.new("UICorner", b)
    b.MouseButton1Click:Connect(function()
        UpdateLanguage(langName)
        LangListFrame.Visible = false
        ShowNotification("Done")
    end)
end

--// نظام التشغيل الذكي
local isUIOpen = true
local function ToggleGhazwanUI()
    if isUIOpen then
        MainFrame:TweenSize(UDim2.new(0, 0, 0, 0), "In", "Back", 0.5, true, function() MainFrame.Visible = false end)
        ShowNotification("UI Minimized 🐾")
    else
        MainFrame.Visible = true
        MainFrame:TweenSize(UDim2.new(0, 500, 0, 350), "Out", "Back", 0.5, true)
        ShowNotification("UI Opened 🔓")
    end
    isUIOpen = not isUIOpen
end

SmartCatCircle.MouseButton1Click:Connect(ToggleGhazwanUI)
MiniButton.MouseButton1Click:Connect(function() if isUIOpen then ToggleGhazwanUI() end end)

local function StartCircleAnimation()
    local info = TweenInfo.new(1, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut, -1, true)
    local goal = {Size = UDim2.new(0, 52, 0, 52)}
    TweenService:Create(SmartCatCircle, info, goal):Play()
end
StartCircleAnimation()

ShowNotification("Script Ready! Created by Ghazwan 💎")
