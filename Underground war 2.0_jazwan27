--// --- RGB Notification System ---
local NotifyGui = Instance.new("ScreenGui", CoreGui)
local function ShowNotification(text)
    local Frame = Instance.new("Frame", NotifyGui)
    Frame.Size = UDim2.new(0, 200, 0, 40)
    Frame.Position = UDim2.new(1, 0, 1, -100)
    Frame.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
    Frame.BorderSizePixel = 0
    Frame.ClipsDescendants = true
    Instance.new("UICorner", Frame).CornerRadius = UDim.new(0, 8)
    local Stroke = Instance.new("UIStroke", Frame)
    Stroke.Thickness = 2
    Stroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    local Label = Instance.new("TextLabel", Frame)
    Label.Size = UDim2.new(1, -10, 1, 0)
    Label.Position = UDim2.new(0, 5, 0, 0)
    Label.BackgroundTransparency = 1
    Label.Text = text
    Label.TextColor3 = Color3.new(1, 1, 1)
    Label.Font = Enum.Font.GothamBold
    Label.TextSize = 14
    local counter = 0
    local rgbConnection = RunService.RenderStepped:Connect(function()
        counter = counter + 0.01
        Stroke.Color = Color3.fromHSV(counter % 1, 1, 1)
        Label.TextColor3 = Color3.fromHSV(counter % 1, 1, 1)
    end)
    Frame:TweenPosition(UDim2.new(1, -210, 1, -100), "Out", "Quart", 0.5, true)
    task.delay(3, function()
        Frame:TweenPosition(UDim2.new(1, 0, 1, -100), "In", "Quart", 0.5, true, function()
            rgbConnection:Disconnect()
            Frame:Destroy()
        end)
    end)
end

