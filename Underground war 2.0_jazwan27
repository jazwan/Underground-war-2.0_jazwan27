local function CreateThemeBtn(color, isRGB)
    local B = Instance.new("TextButton", ColorRow)
    B.Size = UDim2.new(0, 35, 0, 35)
    B.BackgroundColor3 = isRGB and Color3.new(1,1,1) or color
    B.Text = isRGB and "RGB" or ""
    Instance.new("UICorner", B).CornerRadius = UDim.new(1, 0)
    B.MouseButton1Click:Connect(function()
        isRGBTheme = isRGB
        if not isRGB then CurrentThemeColor = color Header.BackgroundColor3 = color end
        ShowNotification("Theme Updated!")
    end)
end
