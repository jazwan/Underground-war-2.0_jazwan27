local function UpdateLanguage(lang)
    local targetData = Languages[lang]
    local function TranslateElement(obj)
        if obj:IsA("TextButton") or obj:IsA("TextLabel") then
            local currentText = obj.Text
            for _, langTable in pairs(Languages) do
                for key, value in pairs(langTable) do
                    if currentText == value then
                        obj.Text = targetData[key]
                        return 
                    end
                end
            end
        end
    end
    for _, item in pairs(MainFrame:GetDescendants()) do
        TranslateElement(item)
    end
    LangBtn.Text = "🌐 " .. targetData.SelectLang .. ": " .. lang
end

local LangBtn = Instance.new("TextButton", Page4)
LangBtn.Size = UDim2.new(0.9, 0, 0, 40)
LangBtn.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
LangBtn.Text = "🌐 Select Language / اختر اللغة"
LangBtn.TextColor3 = Color3.new(1, 1, 1)
LangBtn.Font = Enum.Font.GothamBold
LangBtn.TextSize = 14
Instance.new("UICorner", LangBtn)

local LangListFrame = Instance.new("Frame", Page4)
LangListFrame.Size = UDim2.new(0.9, 0, 0, 150)
LangListFrame.Visible = false
LangListFrame.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
Instance.new("UICorner", LangListFrame)

local LangScroll = Instance.new("ScrollingFrame", LangListFrame)
LangScroll.Size = UDim2.new(1, -10, 1, -10)
LangScroll.Position = UDim2.new(0, 5, 0, 5)
LangScroll.BackgroundTransparency = 1
LangScroll.CanvasSize = UDim2.new(0, 0, 0, 320)
Instance.new("UIListLayout", LangScroll).Padding = UDim.new(0, 5)

LangBtn.MouseButton1Click:Connect(function() 
    LangListFrame.Visible = not LangListFrame.Visible 
end)

for langName, _ in pairs(Languages) do
    local b = Instance.new("TextButton", LangScroll)
    b.Size = UDim2.new(1, 0, 0, 30)
    b.Text = langName
    b.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    b.TextColor3 = Color3.new(1, 1, 1)
    b.Font = Enum.Font.Gotham
    Instance.new("UICorner", b)
    b.MouseButton1Click:Connect(function()
        UpdateLanguage(langName)
        LangListFrame.Visible = false
        ShowNotification("Done")
    end)
end
--// --- [الخطوة الأخيرة: نظام التشغيل الذكي المطور لغزوان] ---

local isUIOpen = true -- الواجهة تبدأ مفتوحة

-- وظيفة الفتح والإغلاق الذكي
local function ToggleGhazwanUI()
    if isUIOpen then
        -- تصغير الواجهة وإخفاؤها
        MainFrame:TweenSize(UDim2.new(0, 0, 0, 0), "In", "Back", 0.5, true, function()
            MainFrame.Visible = false
        end)
        ShowNotification("UI Minimized 🐾")
    else
        -- إظهار الواجهة وتكبيرها
        MainFrame.Visible = true
        MainFrame:TweenSize(UDim2.new(0, 500, 0, 350), "Out", "Back", 0.5, true)
        ShowNotification("UI Opened 🔓")
    end
    isUIOpen = not isUIOpen
end

-- ربط الضغط على دائرة القط بالوظيفة
SmartCatCircle.MouseButton1Click:Connect(function()
    ToggleGhazwanUI()
end)

-- ربط زر الناقص (-) ليعمل بنفس الطريقة
MiniButton.MouseButton1Click:Connect(function()
    if isUIOpen then ToggleGhazwanUI() end
end)

-- إضافة أنيميشن "النبض" المستمر للدائرة لجعلها حية
local function StartCircleAnimation()
    local info = TweenInfo.new(1, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut, -1, true)
    local goal = {Size = UDim2.new(0, 52, 0, 52)}
    TweenService:Create(SmartCatCircle, info, goal):Play()
end
StartCircleAnimation()

ShowNotification("Script Ready! Created by Ghazwan 💎")

        
        
