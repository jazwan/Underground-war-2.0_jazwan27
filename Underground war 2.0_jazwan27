--// Script Button Function
local function CreateScriptBtn(name, parent, urlOrFunc)
    local B = Instance.new("TextButton", parent)
    B.Size = UDim2.new(0.9, 0, 0, 45)
    B.BackgroundColor3 = Color3.fromRGB(180, 0, 0)
    B.Text = name
    B.TextColor3 = Color3.new(1, 1, 1)
    B.Font = Enum.Font.GothamBold
    B.TextSize = 16
    Instance.new("UICorner", B)
    B.MouseButton1Click:Connect(function()
        ShowNotification("[Work completed]")
        if type(urlOrFunc) == "string" then pcall(function() loadstring(game:HttpGet(urlOrFunc))() end) else pcall(urlOrFunc) end
    end)
    return B
end

