--// Tabs and Content
local TabContainer = Instance.new("Frame", MainFrame)
TabContainer.Position = UDim2.new(0, 10, 0, 50)
TabContainer.Size = UDim2.new(0, 135, 1, -65)
TabContainer.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
Instance.new("UIListLayout", TabContainer).Padding = UDim.new(0, 8)

local ContentContainer = Instance.new("Frame", MainFrame)
ContentContainer.Position = UDim2.new(0, 155, 0, 50)
ContentContainer.Size = UDim2.new(1, -165, 1, -65)
ContentContainer.BackgroundColor3 = Color3.fromRGB(20, 20, 20)

local function CreateTabAndContent(name, isPage1)
    local TabButton = Instance.new("TextButton", TabContainer)
    TabButton.Size = UDim2.new(0.9, 0, 0, 38)
    TabButton.BackgroundColor3 = isPage1 and Color3.fromRGB(255, 0, 0) or Color3.fromRGB(180, 0, 0)
    TabButton.Text = name
    TabButton.TextColor3 = Color3.new(1, 1, 1)
    TabButton.Font = Enum.Font.GothamBold
    Instance.new("UICorner", TabButton)

    local Page = Instance.new("ScrollingFrame", ContentContainer)
    Page.Size = UDim2.new(1, 0, 1, 0)
    Page.BackgroundTransparency = 1
    Page.Visible = isPage1
    local Layout = Instance.new("UIListLayout", Page)
    Layout.Padding = UDim.new(0, 10)
    Layout.HorizontalAlignment = Enum.HorizontalAlignment.Center

    TabButton.MouseButton1Click:Connect(function()
        for _, v in pairs(ContentContainer:GetChildren()) do if v:IsA("ScrollingFrame") then v.Visible = false end end
        for _, v in pairs(TabContainer:GetChildren()) do if v:IsA("TextButton") then v.BackgroundColor3 = Color3.fromRGB(180, 0, 0) end end
        TabButton.BackgroundColor3 = Color3.fromRGB(255, 0, 0) 
        Page.Visible = true
    end)
    return Page
end

